<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.jleechan.disk-magician-colima-prune</string>
  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/bash</string>
    <string>@HOME@/projects_other/disk_magician/scripts/cleanup_colima.sh</string>
    <string>--clean</string>
    <string>--prune-volumes</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>DOCKER_VOLUMES_APPROVED</key>
    <string>1</string>
  </dict>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key>
    <integer>0</integer>
    <key>Hour</key>
    <integer>3</integer>
    <key>Minute</key>
    <integer>45</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>/tmp/disk-magician-colima-prune.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/disk-magician-colima-prune.log</string>
</dict>
</plist>
